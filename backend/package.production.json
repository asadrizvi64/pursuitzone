{
  "name": "pursuit-zone-backend",
  "version": "3.0.0",
  "type": "module",
  "description": "Real-world GPS chase game — production backend",
  "main": "src/server.production.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.production.js",
    "start:api": "SERVER_ROLE=api node src/server.production.js",
    "start:worker": "SERVER_ROLE=worker node src/server.production.js",
    "db:init": "psql $DATABASE_URL -f src/models/schema.sql",
    "db:migrate": "psql $DATABASE_URL -f src/models/migrations.sql",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "loadtest": "artillery run loadtest/chase-scenario.yml"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "@socket.io/redis-adapter": "^8.3.0",
    "redis": "^4.6.12",
    "pg": "^8.12.0",
    "ioredis": "^5.3.2",
    "firebase-admin": "^12.0.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.1",
    "twilio": "^4.23.0",
    "stripe": "^14.14.0",
    "zod": "^3.22.4",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "@godaddy/terminus": "^4.12.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "artillery": "^2.0.5",
    "artillery-engine-socketio-v3": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
